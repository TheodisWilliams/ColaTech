{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "icon": {
      "type": "string",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "required": true,
      "maxLength": 160
    },
    "longDescription": {
      "type": "richtext",
      "required": true
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "service.feature"
    },
    "metaTitle": {
      "type": "string",
      "maxLength": 60
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 160
    }
  }
}
