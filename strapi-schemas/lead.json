{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Contact form submissions and quote requests"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "string"
    },
    "services": {
      "type": "text",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "contacted", "quoted", "won", "lost"],
      "default": "new"
    },
    "source": {
      "type": "string",
      "default": "website"
    },
    "submittedAt": {
      "type": "datetime"
    }
  }
}
